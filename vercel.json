PP{
  "version": 2,
  "public": "dist",
  "builds": [
    {
      "src": "vite.config.ts",
      "use": "@vercel/static-build"
    },
    {
      "src": "dist/server.cjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/dist/server.cjs"
    }
  ]
}