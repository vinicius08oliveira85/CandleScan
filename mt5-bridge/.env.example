# Copie para .env e ajuste (arquivo .env não vai para o git)

# Origens permitidas no CORS (separe por vírgula)
BRIDGE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Opcional: exija header X-Bridge-Key nas requisições
# BRIDGE_API_KEY=sua_chave_secreta

# Se a ponte nao achar o MT5 sozinha, cole o caminho do terminal64.exe da Toro:
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
